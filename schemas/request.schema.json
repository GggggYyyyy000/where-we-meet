{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "YuenaRequest",
  "type": "object",
  "required": ["city", "people"],
  "properties": {
    "city": { "type": "string" },
    "query": { "type": "string" },
    "request": { "type": "string" },
    "prompt": { "type": "string" },
    "people": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["name", "address"],
        "properties": {
          "name": { "type": "string" },
          "address": { "type": "string" },
          "mode": {
            "type": "string",
            "description": "个人交通方式。可省略并继承全局 mode；可传 transit/driving/walking，或开车、打车、公交、步行等自然语言。"
          },
          "transportMode": { "type": "string" },
          "travelMode": { "type": "string" },
          "transport": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "poiKeyword": {
      "type": "string",
      "description": "单一偏好类型；兼容旧输入。内部会转为 poiKeywords。"
    },
    "poiKeywords": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "多个可接受类型，例如 [\"湘菜\", \"川菜\"]；默认 OR 语义，合并候选池后排序。"
    },
    "mode": {
      "type": "string",
      "description": "交通方式。可省略，默认 transit；也可传 transit/driving/walking 或包含公交、地铁、开车、打车、步行等自然语言描述。"
    },
    "regionLimit": { "type": "integer", "minimum": 1, "maximum": 10 },
    "candidateLimit": { "type": "integer", "minimum": 1 },
    "clusterRadiusMeters": { "type": "number", "minimum": 1 },
    "minRegionDistanceMeters": { "type": "number", "minimum": 0 },
    "minRegionShopCount": { "type": "integer", "minimum": 1 },
    "outputStem": {
      "type": "string",
      "description": "可选输出文件前缀；不传时自动从 city 和 poiKeywords 生成。"
    },
    "outputHtml": {
      "type": "string",
      "description": "可省略；默认生成 output/<stem>.html。"
    },
    "outputSummary": {
      "type": "string",
      "description": "可省略；默认生成 output/<stem>-summary.md。"
    },
    "outputPersonalMap": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "orgName": { "type": "string" },
        "sceneType": { "type": "integer", "enum": [1, 2, 3] },
        "maxRegions": { "type": "integer", "minimum": 1, "maximum": 10 },
        "shopsPerRegion": { "type": "integer", "minimum": 1 },
        "pointLimit": { "type": "integer", "minimum": 1, "maximum": 16 },
        "qrImage": { "type": "string" },
        "outputJson": { "type": "string" }
      }
    }
  }
}
